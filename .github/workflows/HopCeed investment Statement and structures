from flask import Flask, request, jsonify
from flask_cors import CORS
from flask_jwt_extended import (
    JWTManager, create_access_token, jwt_required, get_jwt_identity
)
import sqlite3, bcrypt, requests

app = Flask(__name__)
CORS(app)

app.config["JWT_SECRET_KEY"] = "super-secret-key"
jwt = JWTManager(app)

# ---------------- DB ----------------
def db():
    return sqlite3.connect("db.sqlite", check_same_thread=False)

# Create tables (run once)
conn = db()
conn.execute("""
CREATE TABLE IF NOT EXISTS users (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    email TEXT,
    password TEXT,
    balance REAL DEFAULT 0
)
""")
conn.commit()

# ---------------- AUTH ----------------

@app.route("/register", methods=["POST"])
def register():
    data = request.json
    hashed = bcrypt.hashpw(data["password"].encode(), bcrypt.gensalt())

    conn = db()
    conn.execute("INSERT INTO users (email, password) VALUES (?, ?)",
                 (data["email"], hashed))
    conn.commit()

    return {"msg": "User created"}

@app.route("/login", methods=["POST"])
def login():
    data = request.json
    cur = db().execute("SELECT id, password FROM users WHERE email=?",
                       (data["email"],))
    user = cur.fetchone()

    if user and bcrypt.checkpw(data["password"].encode(), user[1]):
        token = create_access_token(identity=user[0])
        return {"token": token}

    return {"error": "Invalid login"}, 401

# ---------------- DASHBOARD ----------------

@app.route("/dashboard", methods=["GET"])
@jwt_required()
def dashboard():
    user_id = get_jwt_identity()
    cur = db().execute("SELECT balance FROM users WHERE id=?", (user_id,))
    balance = cur.fetchone()[0]

    return {"balance": balance}

# ---------------- INVEST ----------------

@app.route("/invest", methods=["POST"])
@jwt_required()
def invest():
    user_id = get_jwt_identity()
    amount = request.json["amount"]

    conn = db()
    conn.execute("UPDATE users SET balance = balance + ? WHERE id=?",
                 (amount, user_id))
    conn.commit()

    return {"msg": "Investment added"}

# ---------------- WITHDRAW ----------------

@app.route("/withdraw", methods=["POST"])
@jwt_required()
def withdraw():
    user_id = get_jwt_identity()
    amount = request.json["amount"]

    cur = db().execute("SELECT balance FROM users WHERE id=?", (user_id,))
    balance = cur.fetchone()[0]

    if balance < amount:
        return {"error": "Insufficient funds"}, 400

    conn = db()
    conn.execute("UPDATE users SET balance = balance - ? WHERE id=?",
                 (amount, user_id))
    conn.commit()

    return {"msg": "Withdrawal successful"}

# ---------------- PAYSTACK VERIFY ----------------

PAYSTACK_SECRET = "YOUR_SECRET_KEY"

@app.route("/verify-payment/<ref>")
def verify(ref):
    url = f"https://api.paystack.co/transaction/verify/{ref}"
    headers = {"Authorization": f"Bearer {PAYSTACK_SECRET}"}

    res = requests.get(url, headers=headers).json()

    if res["data"]["status"] == "success":
        amount = res["data"]["amount"] / 100
        email = res["data"]["customer"]["email"]

        conn = db()
        conn.execute("UPDATE users SET balance = balance + ? WHERE email=?",
                     (amount, email))
        conn.commit()

        return {"msg": "Payment verified"}

    return {"error": "Verification failed"}

app.run(debug=True)
